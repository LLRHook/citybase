{
  "name": "citybase",
  "productName": "Citybase",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "main": "electron/main/main.cjs",
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:e2e": "playwright test",
    "dev:desktop": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build:desktop": "vite build",
    "start:desktop": "electron .",
    "core": "node core/server.cjs",
    "package:dir": "npm run build:desktop && electron-builder --dir",
    "package:mac": "npm run build:desktop && electron-builder --mac --config.mac.identity=null",
    "postinstall": "git config core.hooksPath hooks || exit 0",
    "package:v4": "node scripts/package-v4.mjs"
  },
  "build": {
    "appId": "com.llrhook.citybase",
    "productName": "Citybase",
    "asar": true,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "package.json",
      "electron/**/*",
      "dist/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "identity": null
    }
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.9.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  }
}
